<Window x:Class="SimpleGameOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Game Overlay — Settings"
        Height="480" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <StackPanel Margin="20">

        <CheckBox x:Name="EnabledCheckBox" Content="Enable overlay" Margin="0,0,0,15" FontSize="14"/>

        <TextBlock Text="Hotkey (show/hide):" Margin="0,0,0,5"/>
        <TextBox x:Name="HotkeyTextBox" IsReadOnly="True" Margin="0,0,0,15"
                 Text="Press a key combination..." 
                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>

        <TextBlock Text="Text color:" Margin="0,0,0,5"/>
        <Grid Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="R" Grid.Column="0"/>
            <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_Changed"/>
        </Grid>
        <Grid Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="G" Grid.Column="0"/>
            <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_Changed"/>
        </Grid>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="B" Grid.Column="0"/>
            <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_Changed"/>
        </Grid>

        <Border x:Name="ColorPreview" Height="25" Margin="0,0,0,15" BorderBrush="Gray" BorderThickness="1"/>

        <TextBlock Text="Font size:" Margin="0,0,0,5"/>
        <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="40" Margin="0,0,0,15"
                ValueChanged="FontSizeSlider_Changed"/>

        <TextBlock Text="Position X:" Margin="0,0,0,5"/>
        <Slider x:Name="PositionXSlider" Minimum="0" Maximum="1920" Margin="0,0,0,10"
                ValueChanged="PositionSlider_Changed"/>

        <TextBlock Text="Position Y:" Margin="0,0,0,5"/>
        <Slider x:Name="PositionYSlider" Minimum="0" Maximum="1080" Margin="0,0,0,20"
                ValueChanged="PositionSlider_Changed"/>

        <Button Content="Save" Height="35" Click="SaveButton_Click"/>
    </StackPanel>
</Window>